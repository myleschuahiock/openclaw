# Gmail OAuth2 credentials. Copy to extensions/gmail/.env and fill locally.
# Keep the .env file out of version control.

GMAIL_SENDER=miaibarra.bh@gmail.com
GMAIL_USER_ID=me

# From Google Cloud Console OAuth client credentials.
GMAIL_OAUTH_CLIENT_ID=replace-with-client-id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=replace-with-client-secret

# Created by the OAuth helper after the account owner grants consent.
GMAIL_OAUTH_REFRESH_TOKEN=replace-with-refresh-token
# The helper also stores the granted scopes for deterministic capability checks.
GMAIL_OAUTH_GRANTED_SCOPES=https://www.googleapis.com/auth/gmail.send

# Use false for send-only scope. Use true only when the token was generated
# with https://www.googleapis.com/auth/gmail.compose.
GMAIL_ENABLE_DRAFTS=false

# Optional safety and retry overrides.
GMAIL_MAX_RAW_BYTES=36700160
GMAIL_MAX_RETRIES=3
GMAIL_RETRY_BASE_DELAY_MS=500
GMAIL_HTTP_TIMEOUT_MS=15000
